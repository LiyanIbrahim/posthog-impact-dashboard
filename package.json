{
  "name": "posthog-impact-dashboard",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "collect": "node --env-file=.env.local scripts/collect-prs.ts",
